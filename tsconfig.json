{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "frappe-ui": ["./src/types/frappe-ui-shim.d.ts"],
      "frappe-ui/vite": ["./src/types/frappe-ui-vite-shim.d.ts"],
      "frappe-ui/style.css": ["./src/types/style-shim.d.ts"]
    },
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "tests/**/*.ts", "vite.config.ts", "playwright.config.ts"]
}
